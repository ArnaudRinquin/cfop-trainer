---
import '~/styles/global.css';
import type { Locale } from '~/i18n/config';
import { createT } from '~/i18n/strings';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';

interface Props {
  locale: Locale;
  activeRoute: 'dashboard' | 'algorithms' | 'solves' | 'lesson';
  title?: string;
  description?: string;
}

const { locale, activeRoute, title, description } = Astro.props;
const t = createT(locale);
const pageTitle = title ? `${title} — CFOP Trainer` : 'CFOP Trainer';
const pageDescription = description ?? t('app.footer');
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='40' height='40' x='5' y='5' fill='%23fde047' rx='4'/%3E%3Crect width='40' height='40' x='55' y='5' fill='%23ef4444' rx='4'/%3E%3Crect width='40' height='40' x='5' y='55' fill='%2322c55e' rx='4'/%3E%3Crect width='40' height='40' x='55' y='55' fill='%233b82f6' rx='4'/%3E%3C/svg%3E"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&family=Space+Grotesk:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-ink-950 text-ink-100 font-sans antialiased min-h-screen">
    <div class="min-h-screen flex flex-col">
      <Header locale={locale} pathname={Astro.url.pathname} activeRoute={activeRoute} />
      <main class="flex-1">
        <div class="max-w-7xl mx-auto px-5 sm:px-8 py-8 sm:py-12">
          <slot />
        </div>
      </main>
      <Footer locale={locale} />
    </div>
  </body>
</html>
